#include <dt-bindings/zmk/matrix_transform.h>

// Shared hardware-independent definitions.
// GPIO-using nodes (kscan, encoder, sensors) live in the per-half overlays
// so the dongle (XIAO BLE) never encounters &pro_micro references it can't resolve.

/ {
    chosen {
        zmk,kscan = &kscan0;
        zmk,matrix-transform = &default_transform;
    };

    default_transform: matrix_transform {
        compatible = "zmk,matrix-transform";
        columns = <14>;  // 7 per half
        rows = <4>;      // R0 (utils+thumbs), R1 (bottom), R2 (home), R3 (top)

        // Per-half column layout (left overlay: C0→col0 … C6→col6):
        //        C0     C1     C2     C3     C4     C5      C6
        // R3:    outer  pinky  ring   mid    index  inner   ---
        // R2:    outer  pinky  ring   mid    index  inner   ---
        // R1:    outer  pinky  ring   mid    index  inner   enc_push
        // R0:    outer  pinky  ring   mid    index  th_home th_far
        //
        // Right overlay lists columns reversed (C5→col7, C4→col8, … C0→col12, C6→col13)
        // so that col7 = right inner and col12 = right outer, mirroring the left side.

        map = <
            // Row 3 — top letter row (12 keys)
            RC(3,0)  RC(3,1)  RC(3,2)  RC(3,3)  RC(3,4)  RC(3,5)
            RC(3,7)  RC(3,8)  RC(3,9)  RC(3,10) RC(3,11) RC(3,12)
            // Row 2 — home row (12 keys)
            RC(2,0)  RC(2,1)  RC(2,2)  RC(2,3)  RC(2,4)  RC(2,5)
            RC(2,7)  RC(2,8)  RC(2,9)  RC(2,10) RC(2,11) RC(2,12)
            // Row 1 — bottom row + encoder push (14 keys)
            RC(1,0)  RC(1,1)  RC(1,2)  RC(1,3)  RC(1,4)  RC(1,5)  RC(1,6)
            RC(1,7)  RC(1,8)  RC(1,9)  RC(1,10) RC(1,11) RC(1,12) RC(1,13)
            // Row 0 — utils row + thumbfan (14 keys)
            RC(0,0)  RC(0,1)  RC(0,2)  RC(0,3)  RC(0,4)  RC(0,5)  RC(0,6)
            RC(0,7)  RC(0,8)  RC(0,9)  RC(0,10) RC(0,11) RC(0,12) RC(0,13)
        >;
    };
};
