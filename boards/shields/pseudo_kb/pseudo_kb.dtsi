#include <dt-bindings/zmk/matrix_transform.h>

/ {
    chosen {
        zmk,kscan = &kscan0;
        zmk,matrix-transform = &default_transform;
    };

    default_transform: matrix_transform {
        compatible = "zmk,matrix-transform";
        columns = <14>;    // 7 columns × 2 halves
        rows = <5>;        // 5 rows (R0-R4)

        //        outer pinky ring  mid   index inner         inner index mid   ring  pinky outer
        // R3:    key   key   key   key   key   key           key   key   key   key   key   key
        // R2:    key   key   key   key   key   key           key   key   key   key   key   key
        // R1:    key   key   key   key   key   key           key   key   key   key   key   key
        // R0:    key   key   key   key   key         (skip)        key   key   key   key   key
        // R4:                                  thumb thumb   thumb thumb
        // R0:                                  enc            enc

        map = 
            RC(3,0) RC(3,1) RC(3,2) RC(3,3) RC(3,4) RC(3,5)    RC(3,7) RC(3,8) RC(3,9) RC(3,10) RC(3,11) RC(3,12)
            RC(2,0) RC(2,1) RC(2,2) RC(2,3) RC(2,4) RC(2,5)    RC(2,7) RC(2,8) RC(2,9) RC(2,10) RC(2,11) RC(2,12)
            RC(1,0) RC(1,1) RC(1,2) RC(1,3) RC(1,4) RC(1,5)    RC(1,7) RC(1,8) RC(1,9) RC(1,10) RC(1,11) RC(1,12)
            RC(0,0) RC(0,1) RC(0,2) RC(0,3) RC(0,4)                    RC(0,8) RC(0,9) RC(0,10) RC(0,11) RC(0,12)
                                             RC(4,5) RC(4,6)    RC(4,7) RC(4,8)
        >;
    };

    kscan0: kscan0 {
        compatible = "zmk,kscan-gpio-matrix";
        diode-direction = "col2row";
        wakeup-source;

        row-gpios
            = <&pro_micro 5  (GPIO_ACTIVE_HIGH | GPIO_PULL_DOWN)>  // R0 - P5
            , <&pro_micro 9  (GPIO_ACTIVE_HIGH | GPIO_PULL_DOWN)>  // R1 - P8 (mapped to R1 on your PCB)
            , <&pro_micro 10 (GPIO_ACTIVE_HIGH | GPIO_PULL_DOWN)>  // R2
            , <&pro_micro 16 (GPIO_ACTIVE_HIGH | GPIO_PULL_DOWN)>  // R3
            , <&pro_micro 5  (GPIO_ACTIVE_HIGH | GPIO_PULL_DOWN)>  // R4 (thumb row)
            ;
    };
};


/ {
    left_encoder: encoder_left {
        compatible = "alps,ec11";
        a-gpios = <&pro_micro 6 (GPIO_ACTIVE_HIGH | GPIO_PULL_UP)>;   // ENC_A pin
        b-gpios = <&pro_micro 7 (GPIO_ACTIVE_HIGH | GPIO_PULL_UP)>;   // ENC_B pin
        steps = <80>;
    };

    sensors: sensors {
        compatible = "zmk,keymap-sensors";
        sensors = <&left_encoder>;
        triggers-per-rotation = <20>;
    };
};